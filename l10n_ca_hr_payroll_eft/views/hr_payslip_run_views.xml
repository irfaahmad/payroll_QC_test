<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_payslip_run_view_form_eft" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.eft</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <!-- Hidden helper fields so the invisible= expressions can evaluate -->
                <field name="state" invisible="1"/>
                <field name="l10n_ca_eft_generated" invisible="1"/>

                <group string="EFT (CPA 005)" invisible="not l10n_ca_eft_generated">
                    <group>
                        <field name="l10n_ca_eft_settlement_date" readonly="1"/>
                        <field name="l10n_ca_eft_file_number" readonly="1"/>
                        <field name="l10n_ca_eft_payment_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="l10n_ca_eft_file"
                               filename="l10n_ca_eft_filename"
                               readonly="1"
                               widget="binary"/>
                        <field name="l10n_ca_eft_filename" invisible="1"/>
                        <button name="action_download_eft"
                                type="object"
                                string="Re-Download EFT File"
                                class="btn-primary"
                                icon="fa-download"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
