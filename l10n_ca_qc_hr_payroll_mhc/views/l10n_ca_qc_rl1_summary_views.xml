<odoo>

    <!-- RL-1 Summary Form View -->
    <record id="l10n_ca_qc_rl1_summary_form_view" model="ir.ui.view">
        <field name="name">l10n_ca_qc.rl1.summary.form</field>
        <field name="model">l10n_ca_qc.rl1.summary</field>
        <field name="arch" type="xml">
            <form string="RL-1 Summary">
                <header>
                    <button name="action_generate_rl1s"
                            string="Generate RL-1 Slips"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_export_xml"
                            string="Export XML"
                            type="object"
                            class="btn-primary"
                            invisible="state not in ('draft', 'confirmed')"/>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Summary Information">
                            <field name="year"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Transmitter Information">
                            <field name="transmitter_ne"/>
                            <field name="transmitter_name"/>
                            <field name="contact_name"/>
                            <field name="contact_phone"/>
                            <field name="contact_email"/>
                        </group>
                    </group>
                    <group string="Totals">
                        <group>
                            <field name="total_employees"/>
                            <field name="total_box_a"/>
                            <field name="total_box_b"/>
                            <field name="total_box_c"/>
                        </group>
                        <group>
                            <field name="total_box_e"/>
                            <field name="total_box_g"/>
                            <field name="total_box_h"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="RL-1 Slips" name="rl1_slips">
                            <field name="rl1_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="employee_id"/>
                                    <field name="box_a" string="Box A"/>
                                    <field name="box_b" string="Box B"/>
                                    <field name="box_c" string="Box C"/>
                                    <field name="box_e" string="Box E"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-warning="state == 'generated'"
                                           decoration-success="state == 'submitted'"
                                           decoration-danger="state == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- RL-1 Summary List View -->
    <record id="l10n_ca_qc_rl1_summary_list_view" model="ir.ui.view">
        <field name="name">l10n_ca_qc.rl1.summary.list</field>
        <field name="model">l10n_ca_qc.rl1.summary</field>
        <field name="arch" type="xml">
            <list string="RL-1 Summaries">
                <field name="name"/>
                <field name="year"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="total_employees"/>
                <field name="total_box_a"/>
                <field name="total_box_e"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <!-- RL-1 Summary Window Action -->
    <record id="action_l10n_ca_qc_rl1_summary" model="ir.actions.act_window">
        <field name="name">RL-1 Summary</field>
        <field name="res_model">l10n_ca_qc.rl1.summary</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('l10n_ca_qc_rl1_summary_list_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('l10n_ca_qc_rl1_summary_form_view')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No RL-1 summaries found. Create a new one!
            </p>
        </field>
    </record>

</odoo>
