<odoo>

    <!-- ======================== VACATION ACCRUAL VIEWS ======================== -->
    <record id="view_l10n_ca_qc_vacation_accrual_form" model="ir.ui.view">
        <field name="name">l10n_ca_qc.vacation.accrual.form</field>
        <field name="model">l10n_ca_qc.vacation.accrual</field>
        <field name="arch" type="xml">
            <form string="Vacation Pay Accrual">
                <sheet>
                    <group>
                        <group string="Employee">
                            <field name="employee_id"/>
                            <field name="company_id"/>
                            <field name="years_of_service"/>
                        </group>
                        <group string="Accrual">
                            <field name="accrual_rate"/>
                            <field name="accrued_amount"/>
                            <field name="taken_amount"/>
                            <field name="balance"/>
                            <field name="last_updated"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_ca_qc_vacation_accrual_list" model="ir.ui.view">
        <field name="name">l10n_ca_qc.vacation.accrual.list</field>
        <field name="model">l10n_ca_qc.vacation.accrual</field>
        <field name="arch" type="xml">
            <list string="Vacation Pay Accrual">
                <field name="employee_id"/>
                <field name="years_of_service"/>
                <field name="accrual_rate"/>
                <field name="accrued_amount"/>
                <field name="taken_amount"/>
                <field name="balance"/>
                <field name="last_updated"/>
            </list>
        </field>
    </record>


    <record id="view_l10n_ca_qc_vacation_accrual_search" model="ir.ui.view">
        <field name="name">l10n_ca_qc.vacation.accrual.search</field>
        <field name="model">l10n_ca_qc.vacation.accrual</field>
        <field name="arch" type="xml">
            <search string="Vacation Pay Accrual">
                <field name="employee_id"/>
            </search>
        </field>
    </record>

    <record id="action_l10n_ca_qc_vacation_accrual" model="ir.actions.act_window">
        <field name="name">Vacation Pay Accrual</field>
        <field name="res_model">l10n_ca_qc.vacation.accrual</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ======================== GARNISHMENT VIEWS ======================== -->
    <record id="view_l10n_ca_qc_garnishment_form" model="ir.ui.view">
        <field name="name">l10n_ca_qc.garnishment.form</field>
        <field name="model">l10n_ca_qc.garnishment</field>
        <field name="arch" type="xml">
            <form string="Garnishment / Court-Ordered Deduction">
                <sheet>
                    <group>
                        <group string="General">
                            <field name="employee_id"/>
                            <field name="company_id"/>
                            <field name="garnishment_type"/>
                            <field name="description"/>
                            <field name="priority"/>
                            <field name="active"/>
                        </group>
                        <group string="Deduction">
                            <field name="is_percentage"/>
                            <field name="percentage" invisible="not is_percentage" required="is_percentage"/>
                            <field name="amount" invisible="is_percentage" required="not is_percentage"/>
                            <field name="exempt_amount"/>
                        </group>
                        <group string="Dates &amp; Balance">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="balance_remaining"/>
                            <field name="total_deducted"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_ca_qc_garnishment_list" model="ir.ui.view">
        <field name="name">l10n_ca_qc.garnishment.list</field>
        <field name="model">l10n_ca_qc.garnishment</field>
        <field name="arch" type="xml">
            <list string="Garnishments">
                <field name="employee_id"/>
                <field name="garnishment_type"/>
                <field name="description"/>
                <field name="is_percentage"/>
                <field name="percentage"/>
                <field name="amount"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="active"/>
                <field name="total_deducted"/>
            </list>
        </field>
    </record>


    <record id="action_l10n_ca_qc_garnishment" model="ir.actions.act_window">
        <field name="name">Garnishments</field>
        <field name="res_model">l10n_ca_qc.garnishment</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <!-- ======================== REMITTANCE REPORT VIEWS ======================== -->
    <record id="view_l10n_ca_qc_remittance_report_form" model="ir.ui.view">
        <field name="name">l10n_ca_qc.remittance.report.form</field>
        <field name="model">l10n_ca_qc.remittance.report</field>
        <field name="arch" type="xml">
            <form string="Remittance Report">
                <header>
                    <button name="action_compute" string="Compute" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_submit" string="Mark Submitted" type="object"
                            invisible="state != 'computed'"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,computed,submitted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="period_start"/>
                            <field name="period_end"/>
                            <field name="payslip_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employee Deductions">
                            <group>
                                <field name="total_qpp_ee"/>
                                <field name="total_qpp2_ee"/>
                                <field name="total_qpip_ee"/>
                                <field name="total_ei_ee"/>
                                <field name="total_fed_tax"/>
                                <field name="total_prov_tax"/>
                            </group>
                        </page>
                        <page string="Employer Contributions">
                            <group>
                                <field name="total_qpp_er"/>
                                <field name="total_qpp2_er"/>
                                <field name="total_qpip_er"/>
                                <field name="total_ei_er"/>
                                <field name="total_cnesst"/>
                                <field name="total_hsf"/>
                                <field name="total_cnt"/>
                            </group>
                        </page>
                        <page string="Summary">
                            <group>
                                <field name="total_gross"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_ca_qc_remittance_report_list" model="ir.ui.view">
        <field name="name">l10n_ca_qc.remittance.report.list</field>
        <field name="model">l10n_ca_qc.remittance.report</field>
        <field name="arch" type="xml">
            <list string="Remittance Reports">
                <field name="name"/>
                <field name="company_id"/>
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="payslip_count"/>
                <field name="total_gross"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_l10n_ca_qc_remittance_report" model="ir.actions.act_window">
        <field name="name">Remittance Reports</field>
        <field name="res_model">l10n_ca_qc.remittance.report</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ======================== T4 SLIP VIEWS ======================== -->
    <record id="view_l10n_ca_qc_t4_slip_form" model="ir.ui.view">
        <field name="name">l10n_ca_qc.t4.slip.form</field>
        <field name="model">l10n_ca_qc.t4.slip</field>
        <field name="arch" type="xml">
            <form string="T4 Slip">
                <header>
                    <button name="action_generate" string="Generate" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_export_xml" string="Export XML" type="object"
                            invisible="state == 'draft'"/>
                    <button name="action_submit" string="Submit to CRA" type="object"
                            invisible="state != 'generated'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('draft', 'cancelled')"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,generated,submitted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="company_id"/>
                            <field name="year"/>
                            <field name="summary_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employment Income">
                            <group>
                                <field name="box_14" string="Box 14 — Employment Income"/>
                                <field name="box_24" string="Box 24 — EI Insurable Earnings"/>
                                <field name="box_26" string="Box 26 — QPP Pensionable Earnings"/>
                            </group>
                        </page>
                        <page string="Deductions">
                            <group>
                                <field name="box_16" string="Box 16 — QPP Employee Contributions"/>
                                <field name="box_17" string="Box 17 — QPP2 Employee Contributions"/>
                                <field name="box_18" string="Box 18 — EI Premiums"/>
                                <field name="box_20" string="Box 20 — RPP Contributions"/>
                                <field name="box_22" string="Box 22 — Federal Income Tax Deducted"/>
                                <field name="box_44" string="Box 44 — Union Dues"/>
                                <field name="box_55" string="Box 55 — QPIP Premiums"/>
                                <field name="box_56" string="Box 56 — QPIP Insurable Earnings"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_ca_qc_t4_slip_list" model="ir.ui.view">
        <field name="name">l10n_ca_qc.t4.slip.list</field>
        <field name="model">l10n_ca_qc.t4.slip</field>
        <field name="arch" type="xml">
            <list string="T4 Slips">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="year"/>
                <field name="box_14"/>
                <field name="box_22"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_l10n_ca_qc_t4_slip" model="ir.actions.act_window">
        <field name="name">T4 Slips</field>
        <field name="res_model">l10n_ca_qc.t4.slip</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ======================== T4 SUMMARY VIEWS ======================== -->
    <record id="view_l10n_ca_qc_t4_summary_form" model="ir.ui.view">
        <field name="name">l10n_ca_qc.t4.summary.form</field>
        <field name="model">l10n_ca_qc.t4.summary</field>
        <field name="arch" type="xml">
            <form string="T4 Summary">
                <header>
                    <button name="action_generate_t4s" string="Generate T4 Slips" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_export_xml" string="Export XML (T619)" type="object"
                            invisible="state == 'draft' or not slip_ids"/>
                    <button name="action_submit" string="Submit to CRA" type="object"
                            invisible="state != 'draft' or not slip_ids"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="year"/>
                        </group>
                        <group>
                            <field name="total_employment_income"/>
                            <field name="total_income_tax"/>
                            <field name="total_ei_premiums"/>
                            <field name="total_qpp_contributions"/>
                        </group>
                    </group>
                    <field name="slip_ids">
                        <list>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="box_14" string="Box 14"/>
                            <field name="box_22" string="Box 22"/>
                            <field name="box_16" string="Box 16 QPP"/>
                            <field name="box_18" string="Box 18 EI"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'draft'"
                                   decoration-warning="state == 'generated'"
                                   decoration-success="state == 'submitted'"
                                   decoration-danger="state == 'cancelled'"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_ca_qc_t4_summary_list" model="ir.ui.view">
        <field name="name">l10n_ca_qc.t4.summary.list</field>
        <field name="model">l10n_ca_qc.t4.summary</field>
        <field name="arch" type="xml">
            <list string="T4 Summaries">
                <field name="name"/>
                <field name="company_id"/>
                <field name="year"/>
                <field name="total_employment_income"/>
                <field name="total_income_tax"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_l10n_ca_qc_t4_summary" model="ir.actions.act_window">
        <field name="name">T4 Summaries</field>
        <field name="res_model">l10n_ca_qc.t4.summary</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
